# ─── Flow — Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is git-ignored; .env.example is committed as documentation.

# PocketBase backend URL (required)
# Your running PocketBase instance — no trailing slash.
VITE_PB_URL=https://your-pocketbase-url.com

# Error reporting endpoint (optional)
# When set, unhandled errors + Vue component errors are POSTed here as JSON.
# Points at anything that accepts a POST of an array of error payloads:
#   - Sentry's tunnel/relay endpoint
#   - A serverless function you own
#   - Logflare / Logtail / Better Stack ingestion URLs
#   - Your own backend's /errors route
# Leave unset to skip remote reporting (errors still log to the console).
# VITE_ERROR_REPORT_URL=https://your-error-endpoint.example.com/ingest

# Release identifier (optional)
# Stamps each error payload with this string so you can correlate reports
# with a specific deploy. CI usually sets this to the git SHA.
# VITE_RELEASE=flow@1.0.0
